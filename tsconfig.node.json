{
  // "bundler" from the base config is incompatible with "module": "commonjs" (TS5095). node10 matches CJS prebuild scripts.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node10",
    "types": ["node"]
  },
  "include": ["prebuildLessons.ts", "prebuildPresets.ts", "prebuildPresetSets.ts", "zipdist.ts"],
  "exclude": []
}
